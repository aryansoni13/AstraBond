rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Couples
    match /couples/{coupleId} {
      // Anyone authenticated can read (needed for invite code lookup when joining)
      allow read: if request.auth != null;

      // Only the creator (who will be in members[]) can create
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.members;

      // Existing members can update OR a new user can join if:
      // - couple has < 2 members currently
      // - they are adding themselves to members
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members ||
        (
          resource.data.members.size() < 2 &&
          request.auth.uid in request.resource.data.members
        )
      );
    }

    // Activities: any authenticated user can read/write activities for their couple
    // Simplified rule — just check the user is authenticated and owns the activity they write
    match /activities/{activityId} {
      // Anyone authenticated can read activities (query is filtered by coupleId client-side)
      allow read: if request.auth != null;

      // Can create if logged in and userId matches
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;

      // Can update if authenticated (to add reactions)
      allow update: if request.auth != null;

      // Can delete only own activities
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // Nudges: used for real-time couple pokes
    match /nudges/{nudgeId} {
      // Allow reading nudges
      allow read: if request.auth != null;
      
      // Allow creating a nudge
      allow create: if request.auth != null;
      
      // Allow deleting a nudge once acknowledged
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.toUserId;
    }
  }
}
